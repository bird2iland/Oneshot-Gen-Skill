# =============================================================================
# Oneshot-Gen-Skill Project .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# 排除文件夹 - 本地配置和测试
# -----------------------------------------------------------------------------
.claude/
.opencode/
参考手册/
测试用图/
调试日志/

# -----------------------------------------------------------------------------
# macOS 系统文件
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Python 虚拟环境
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv

# -----------------------------------------------------------------------------
# IDE 和编辑器
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# 测试和覆盖率
# -----------------------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# -----------------------------------------------------------------------------
# Jupyter Notebook
# -----------------------------------------------------------------------------
.ipynb_checkpoints

# -----------------------------------------------------------------------------
# pyenv
# -----------------------------------------------------------------------------
.python-version

# -----------------------------------------------------------------------------
# 敏感数据 - 凭证和密钥（排除这些，但保留 data/ 目录）
# -----------------------------------------------------------------------------
data/credentials.json
data/.key

# -----------------------------------------------------------------------------
# Tauri / Rust
# -----------------------------------------------------------------------------
**/src-tauri/target/
**/target/
**/src-tauri/gen/
**/*.rlib
**/*.d

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
**/node_modules/
**/dist/
**/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# 日志文件
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# 临时文件
# -----------------------------------------------------------------------------
*.tmp
*.temp
.cache/
